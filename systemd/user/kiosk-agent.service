# kiosk-client agent user service
#
# This service starts the local kiosk-agent in the user manager.
# The agent exposes local HTTP status endpoints and monitors the browser
# runtime without controlling it.

[Unit]
Description=kiosk-client agent
After=default.target

[Service]
WorkingDirectory=%h/kiosk-client
ExecStart=%h/kiosk-client/kiosk-agent
Restart=always
RestartSec=3

[Install]
WantedBy=default.target
