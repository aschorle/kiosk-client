# kiosk-client Cage runtime user service
#
# This service starts the productive appliance runtime path:
# Cage -> Chromium -> configured URL.

[Unit]
Description=kiosk-client Cage runtime
After=graphical-session.target
BindsTo=graphical-session.target
PartOf=graphical-session.target

[Service]
WorkingDirectory=%h/kiosk-client
ExecStart=%h/kiosk-client/scripts/start-cage.sh
Restart=always
RestartSec=3

[Install]
WantedBy=graphical-session.target
